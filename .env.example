# .env.example — copy to .env (which is gitignored) and populate.
#
# All prompts ship as environment variables, not files. This keeps prompt
# content out of the source tree — nothing sensitive is visible to anyone
# reading the repo on GitHub.
#
# Loader: pilotd/pilot/prompts.py
# Required set: PILOT_PROMPT_* keys below. Missing keys fail loud at daemon
# startup.
#
# For multi-line values, keep the value on one line and use \n escapes, OR
# use Python-dotenv triple-quoted blocks:
#   PILOT_PROMPT_FOO="""
#   Line 1
#   Line 2
#   """

# --- API credentials ---------------------------------------------------------

ANTHROPIC_API_KEY=sk-ant-REPLACE-ME

# --- Model selection (defaults live in pilotd/pilot/config.py once ported) ---

PILOT_MODEL_VISION=claude-sonnet-4-20250514
PILOT_MODEL_PLANNER=claude-sonnet-4-20250514
PILOT_MODEL_LIGHT=claude-haiku-4-5-20251001

# --- Prompts (filled in .env — do NOT paste content into .env.example) -------

# NL-description -> workflow YAML (authoring draft path)
PILOT_PROMPT_DRAFT_WORKFLOW="<provide in .env>"

# NL-cadence -> cron expression (Schedule tab helper)
PILOT_PROMPT_CRON_PARSE="<provide in .env>"

# Failure diagnosis (History tab / retry reasoning)
PILOT_PROMPT_DIAGNOSE_FAILURE="<provide in .env>"

# Primary agent system prompt (observe/think/act)
PILOT_PROMPT_AGENT_SYSTEM="<provide in .env>"

# Task planner (task -> 2-15 steps)
PILOT_PROMPT_TASK_PLANNER="<provide in .env>"

# Safety-guard evaluator (task/action risk scoring)
PILOT_PROMPT_SAFETY_GUARD="<provide in .env>"

# --- Runtime paths (optional overrides) --------------------------------------

# PILOT_HOME=~/Library/Application Support/Pilot
# PILOT_SOCKET=~/Library/Application Support/Pilot/pilotd.sock
# PILOT_DB=~/Library/Application Support/Pilot/memory.db

# --- Budget caps -------------------------------------------------------------

# PILOT_DAILY_BUDGET_USD=5.00
# PILOT_MONTHLY_BUDGET_USD=50.00
