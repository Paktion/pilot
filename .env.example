# .env.example — copy to .env (which is gitignored) and populate.
#
# Prompts are NOT stored here. They live as individual files under
#   $PILOT_HOME/prompts/<name>.md    (default: ~/Library/Application Support/Pilot/prompts/)
# The loader reads those files first and falls back to PILOT_PROMPT_<NAME>
# env vars only if the file is missing — useful for hermetic tests.
#
# Expected files (lowercase, one per prompt):
#   draft_workflow.md     — NL-description -> workflow YAML
#   cron_parse.md         — NL-cadence -> cron expression
#   diagnose_failure.md   — failure post-mortem
#   agent_system.md       — primary agent system prompt
#   task_planner.md       — task -> step list
#   safety_guard.md       — action risk scoring
#   extract_answer.md     — vision-QA extraction
#   goal_agent.md         — goal-directed agent system prompt
#   replan.md             — replan on step failure
#   success_criteria.md   — goal completion evaluator

# --- API credentials ---------------------------------------------------------

ANTHROPIC_API_KEY=sk-ant-REPLACE-ME

# --- Model selection ---------------------------------------------------------
# Keys MUST match Config.CONFIG_SCHEMA (pilotd/pilot/core/config.py):
#   PILOT_MODEL        -> config key "model"        (Sonnet/Opus tier)
#   PILOT_MODEL_LIGHT  -> config key "model_light"  (Haiku tier)
# Any other PILOT_MODEL_* name is silently ignored by the loader.

PILOT_MODEL=claude-sonnet-4-6
PILOT_MODEL_LIGHT=claude-haiku-4-5-20251001

# --- Runtime paths (optional overrides) --------------------------------------

# PILOT_HOME=~/Library/Application Support/Pilot
# PILOT_SOCKET=~/Library/Application Support/Pilot/pilotd.sock
# PILOT_DB=~/Library/Application Support/Pilot/memory.db

# --- Budget caps -------------------------------------------------------------

# PILOT_DAILY_BUDGET_USD=5.00
# PILOT_MONTHLY_BUDGET_USD=50.00
